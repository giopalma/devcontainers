{
  "id": "haskell",
  "version": "0.0.4",
  "name": "Haskell",
  "publisher": "Giovanni Palma (@giopalma)",
  "description": "A Template for Haskell development.",
  "options": {
    "happy-version": {
      "type": "string",
      "description": "The version of Happy to use.",
      "enum": ["2.2"],
      "default": "2.2"
    },
    "alex-version": {
      "type": "string",
      "description": "The version of Alex to use.",
      "enum": ["3.5.4.2"],
      "default": "3.5.4.2"
    },
    "bnfc-version": {
      "type": "string",
      "description": "The version of BNFC to use.",
      "enum": ["2.9.6.3"],
      "default": "2.9.6.3"
    },
    "ghc-version": {
      "type": "string",
      "description": "The version of GHC to use.",
      "enum": ["9.14.1"],
      "default": "9.14.1"
    }
  },
  "platforms": ["Haskell"]
}
